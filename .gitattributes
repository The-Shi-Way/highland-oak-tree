# Auto-detect text files and normalise line endings
* text=auto eol=lf

# Explicitly declare text files
*.ts text
*.tsx text
*.js text
*.json text
*.md text
*.yml text
*.yaml text
*.vue text
*.css text
*.html text
*.tf text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
